# ---------------------------------------------------------------------------
# Epiminded web funnel — environment
# Copy to `.env.local`. Every value is OPTIONAL: with none set, the funnel runs
# end-to-end in MOCK mode (simulated payment + in-memory provisioning).
# ---------------------------------------------------------------------------

# Public base URL of this web funnel (used for Stripe redirects + handoff links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (optional) ------------------------------------------------------
# If STRIPE_SECRET_KEY is unset, the checkout step is simulated (no real charge).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Per-offer recurring price ids (Track B). Naming: STRIPE_PRICE_<OFFER>_<INTERVAL>.
# Offers: COMMUNITY, LITE, STANDARD, PRO · Intervals: MONTH, YEAR.
STRIPE_PRICE_COMMUNITY_MONTH=
STRIPE_PRICE_COMMUNITY_YEAR=
STRIPE_PRICE_LITE_MONTH=
STRIPE_PRICE_LITE_YEAR=
STRIPE_PRICE_STANDARD_MONTH=
STRIPE_PRICE_STANDARD_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
# Optional voice-print add-on price id (recurring).
STRIPE_PRICE_ADDON=
# Optional single fallback price id used when a per-offer id above is unset.
STRIPE_PRICE_ID=

# --- Entitlement token (mock signing) --------------------------------------
# HS256 secret used to sign the handoff entitlement token. A dev default is
# used if unset — DO NOT rely on the default in production.
ENTITLEMENT_TOKEN_SECRET=dev-only-insecure-secret-change-me

# Deep-link scheme the mobile app registers (universal/app link host or scheme).
NEXT_PUBLIC_APP_DEEPLINK_SCHEME=epiminded
NEXT_PUBLIC_APP_UNIVERSAL_LINK=https://open.epiminded.app
