# ---------------------------------------------------------------------------
# Epiminded web funnel — environment
# Copy to `.env.local`. Do not commit real secrets.
# ---------------------------------------------------------------------------

# Public app URL used for checkout success + return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backward-compatible alias used in older code paths.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Polar checkout (required) ----------------------------------------------
# Sandbox example:
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=polar_oat_Ni5b648LT0r7pIln4K53gDiBTxPPW1fkP2A5V0gN9Bk
POLAR_PRODUCT_ID=

# Production example (switch from sandbox by changing values):
# POLAR_SERVER=production
# POLAR_ACCESS_TOKEN=polar_oat_qxj6FvUJ3jowESPLJRKsJcCgnndI997xnenNL4eNEzn
# POLAR_PRODUCT_ID=

# Optional explicit success URL template.
SUCCESS_URL=http://localhost:3000/success?checkout_id={CHECKOUT_ID}
# Optional webhook secret if webhook route is used.
POLAR_WEBHOOK_SECRET=

# Per-offer product ids (optional, used by paywall pricing cards).
# Naming: POLAR_PRODUCT_<OFFER>_<INTERVAL>
POLAR_PRODUCT_LITE_MONTH=ed645dbc-b203-4918-a8d1-9ae31dc068df
POLAR_PRODUCT_LITE_YEAR=e533fd93-72a2-41ec-9a8e-420ef2454481
POLAR_PRODUCT_STANDARD_MONTH=15948a33-93ff-479c-89c9-2eb0262da0b9
POLAR_PRODUCT_STANDARD_YEAR=144a19c9-17d4-40c4-96bd-3f3aa0efaea4
POLAR_PRODUCT_PRO_MONTH=7f3523f0-19ec-4ffe-b60c-0250b73058d0
POLAR_PRODUCT_PRO_YEAR=00d7d1fa-fc55-4731-91bb-db3bafdd05c8

# --- Entitlement token (mock signing) ---------------------------------------
ENTITLEMENT_TOKEN_SECRET=dev-only-insecure-secret-change-me

# Deep-link config.
NEXT_PUBLIC_APP_DEEPLINK_SCHEME=epiminded
NEXT_PUBLIC_APP_UNIVERSAL_LINK=https://open.epiminded.app

# --- External auth/OTP service ------------------------------------------------
# Optional base URL used by /api/auth/register and /api/auth/verify-otp proxy routes.
AUTH_API_BASE_URL=http://40.89.185.79:4006
# Optional explicit overrides (uncomment to use custom paths):
# AUTH_REGISTER_URL=http://40.89.185.79:4006/api/auth/register
# AUTH_VERIFY_OTP_URL=http://40.89.185.79:4006/api/auth/verify-email
# AUTH_RESEND_VERIFICATION_URL=http://40.89.185.79:4006/api/auth/resend-verification
# AUTH_JOIN_COMMUNITY_BY_CODE_URL=http://40.89.185.79:5044/join-community-by-code

# --- Subscription / plans service --------------------------------------------
# Used by provision + payment-status sync, and by dynamic paywall plans.
# SUBSCRIPTION_API_BASE_URL=http://40.89.185.79:5029
# Optional explicit override for web plans:
# PLANS_WEB_URL=http://40.89.185.79:5029/plans/web

# Web discount vs mobile/store base prices (percent). Used by pricing UI.
# webPrice = mobilePrice * (1 - NEXT_PUBLIC_WEB_DISCOUNT_PERCENT / 100)
NEXT_PUBLIC_WEB_DISCOUNT_PERCENT=30
