# ---------------------------------------------------------------------------
# Epiminded web funnel — environment
# Copy to `.env.local`. Polar vars are required for real checkout.
# ---------------------------------------------------------------------------

# Public base URL of this web funnel (used for redirects + handoff links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Polar production (required for checkout) -------------------------------
POLAR_ACCESS_TOKEN=polar_oat_nAp44viOPBqT0pGrSA6EydzVXTfu5hERvO9uR30w5wH
POLAR_WEBHOOK_SECRET=
SUCCESS_URL=http://localhost:3000/success?checkout_id={CHECKOUT_ID}

# Per-offer Polar product ids. Naming: POLAR_PRODUCT_<OFFER>_<INTERVAL>.
# Offers: LITE, STANDARD, PRO · Intervals: MONTH, YEAR.
POLAR_PRODUCT_LITE_MONTH=b3ceb3d4-135a-456b-95db-d7b5776d81b6
POLAR_PRODUCT_LITE_YEAR=0678c011-cd77-40ab-9cbf-33f9470b508c
POLAR_PRODUCT_STANDARD_MONTH=cad98502-c72c-4431-a92d-910b868b97f9
POLAR_PRODUCT_STANDARD_YEAR=38923219-414f-40e2-a6e0-e7b22c299ff6
POLAR_PRODUCT_PRO_MONTH=f6b89faa-5a1e-48e5-9e14-e0e7ab60d255
POLAR_PRODUCT_PRO_YEAR=e86b33c5-acef-4aad-9c13-4ff9bb440e75

# --- Entitlement token (mock signing) --------------------------------------
# HS256 secret used to sign the handoff entitlement token. A dev default is
# used if unset — DO NOT rely on the default in production.
ENTITLEMENT_TOKEN_SECRET=dev-only-insecure-secret-change-me

# Deep-link scheme the mobile app registers (universal/app link host or scheme).
NEXT_PUBLIC_APP_DEEPLINK_SCHEME=epiminded
NEXT_PUBLIC_APP_UNIVERSAL_LINK=https://open.epiminded.app
